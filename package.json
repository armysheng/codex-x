{
  "name": "codex-x",
  "private": true,
  "version": "0.1.0",
  "description": "Memory-first Codex workspace template, bootstrapper, and optional Feishu bridge.",
  "type": "module",
  "bin": {
    "codex-x": "./bin/codex-x.mjs"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test ./test/root-cli.test.mjs && npm run test --workspaces --if-present",
    "lint:names": "node ./scripts/check-redactions.mjs",
    "init:workspace": "node ./bin/codex-x.mjs init"
  }
}
